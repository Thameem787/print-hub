# MongoDB Atlas connection string
# Replace with your actual connection string from Atlas
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/printhub?retryWrites=true&w=majority

# JWT secret — use a long random string in production
JWT_SECRET=printhub_secret_change_me_in_production

# Server port
PORT=5000

# Frontend URL (for CORS) — update when deployed
CLIENT_URL=http://localhost:5173
